# Supabase Configuration (set these in Netlify Dashboard → Site Settings → Environment Variables)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# n8n Webhook Integration (optional — app works without it)
NEXT_PUBLIC_N8N_WEBHOOK_URL=http://localhost:5678
